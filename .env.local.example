# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real values.

# The canonical public URL of the site (no trailing slash).
# Used for sitemap, robots.txt, canonical tags, and OG metadata.
NEXT_PUBLIC_SITE_URL=https://cat3books.com

# The base URL used for internal API calls or asset paths.
# Usually the same as NEXT_PUBLIC_SITE_URL.
NEXT_PUBLIC_BASE_URL=https://cat3books.com

# The human-readable site name used in metadata and the title template.
NEXT_PUBLIC_SITE_NAME=Cat3 Books
